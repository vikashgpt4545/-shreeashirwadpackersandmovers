<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent Directory Browsing
    Options -Indexes

    # Allow existing files and directories to pass through
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route clean URLs to pages/ directory
    # e.g., /packers-and-movers-in-ranchi -> pages/packers-and-movers-in-ranchi.php
    RewriteRule ^([^/]+)/?$ pages/$1.php [L,QSA]

    # Route clean blog URLs to pages/blog/ directory
    RewriteRule ^blog/([^/]+)/?$ pages/blog/$1.php [L,QSA]

    # Custom 404 Error Page
    ErrorDocument 404 /pages/404.php
</IfModule>
